{
  "name": "physiophixx-desktop",
  "version": "1.0.0",
  "description": "Physiophixx Clinic Management - Windows Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.physiophixx.desktop",
    "productName": "Physiophixx",
    "files": [
      "index.html",
      "app.js",
      "main.js",
      "icon.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
